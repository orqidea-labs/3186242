    {
      "name": "Registro Usuario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuario1@ejemplo.com\",\n  \"password\": \"12345\"\n}"
        },
        "url": {
          "raw": "http://host.docker.internal:5001/register",
          "protocol": "http",
          "host": ["host.docker.internal"],
          "port": "5001",
          "path": ["register"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Contiene mensaje de éxito', function () {",
              "    pm.expect(pm.response.text()).to.include('Usuario registrado');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
